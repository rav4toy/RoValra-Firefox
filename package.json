    "sass": "^1.99.0"
  },
  "dependencies": {
    "dompurify": "^3.4.0",
    "i18next": "26.0.6",
    "marked": "^18.0.2",
    "roavatar-renderer": "1.2.14"
  },
  "lint-staged": {
